# --- ChatLoom Deployment Template ---
# Copy this file to '.env' on your server and fill in the values.

# 1. Cloudflare Tunnel Token (From Zero Trust Dashboard)
CHATLOOM_TUNNEL_TOKEN=your_token_here

# 2. Secret Key for Flask sessions (Long random string)
CHATLOOM_SECRET_KEY=generate_a_random_secret_here

# 3. Allowed Domains for CORS (Comma separated)
# Example: https://chatloom.online,https://www.chatloom.online
CHATLOOM_EXTRA_ORIGINS=https://your-frontend-domain.com
